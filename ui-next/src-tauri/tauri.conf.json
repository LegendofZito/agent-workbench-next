{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Workbench Next",
  "version": "0.1.0",
  "identifier": "com.agentworkbench.next",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agent Workbench Next",
        "width": 1480,
        "height": 920,
        "minWidth": 920,
        "minHeight": 640,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.config/agent-workbench/artifacts/**"
        ]
      }
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon-2.png"]
  }
}
